      "{'start_symbol': 'S', 'nonterminals': ['S'], 'surface_terminals': ['b', 'a'], 'num_rules': 4, 'num_brackets': 24, 'allowed_starts': ['OB__0__1', 'OB__1__1', 'OB__2__1', 'OB__3__1'], 'allowed_finals': ['CB__0__3', 'CB__1__4', 'CB__2__4', 'CB__3__1'], 'local_builder': 'direct', 'sent_builder': 'direct'}\n",
